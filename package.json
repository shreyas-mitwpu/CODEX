{
  "name": "factorymind",
  "version": "1.0.0",
  "description": "Production-ready WhatsApp inventory management for factories",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch scripts/demo-server.ts",
    "dev:api": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/scripts/demo-server.js",
    "start:api": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa:stress": "node scripts/qa-demo-stress.mjs",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "doctor": "tsx scripts/doctor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "twilio": "^5.7.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.32",
    "@types/pg": "^8.15.4",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
